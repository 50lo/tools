#!/usr/bin/env bash
set -euo pipefail

LINEAGE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LINEAGE_TOOL_MARKER="Installed by lineage. Do not edit manually."
LINEAGE_DEFAULT_NOTES_REF="refs/notes/lineage"
LINEAGE_DEFAULT_EXTRACTOR="${LINEAGE_ROOT}/scripts/extract-session-stub.sh"

usage() {
  cat <<'EOF'
lineage - automatic commit lineage notes from coding-session transcripts

Usage:
  lineage install [REPO_PATH] [--extractor PATH] [--notes-ref REF] [--force]
  lineage hook post-commit
  lineage hook post-rewrite [rewrite-command]
  lineage attach <commit-ish> [--event EVENT]

Commands:
  install           Install lineage hooks and repo-local config
  hook post-commit  Hook entrypoint: capture transcript and write git note
  hook post-rewrite Hook entrypoint: copy notes for rewritten commits
  attach            Manually attach a lineage note to a specific commit
EOF
}

info() {
  printf 'lineage: %s\n' "$*" >&2
}

warn() {
  printf 'lineage: warning: %s\n' "$*" >&2
}

die() {
  printf 'lineage: error: %s\n' "$*" >&2
  exit 1
}

now_utc() {
  date -u +"%Y-%m-%dT%H:%M:%SZ"
}

repo_log() {
  local level="$1"
  local message="$2"
  local git_dir
  git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"
  [ -n "$git_dir" ] || return 0

  mkdir -p "${git_dir}/lineage" 2>/dev/null || true
  printf '%s [%s] %s\n' "$(now_utc)" "$level" "$message" >> "${git_dir}/lineage/lineage.log" 2>/dev/null || true
}

validate_notes_ref() {
  local notes_ref="$1"
  [[ "$notes_ref" == refs/notes/* ]]
}

resolve_notes_ref() {
  local configured
  configured="$(git config --local --get lineage.notesRef 2>/dev/null || true)"
  if [ -z "$configured" ]; then
    printf '%s\n' "$LINEAGE_DEFAULT_NOTES_REF"
    return 0
  fi

  if validate_notes_ref "$configured"; then
    printf '%s\n' "$configured"
    return 0
  fi

  warn "invalid lineage.notesRef '$configured'; using default '$LINEAGE_DEFAULT_NOTES_REF'"
  repo_log "WARN" "Invalid notes ref '$configured'; fell back to '$LINEAGE_DEFAULT_NOTES_REF'"
  printf '%s\n' "$LINEAGE_DEFAULT_NOTES_REF"
}

resolve_extractor_path() {
  local repo_root="$1"
  local configured
  configured="$(git config --local --get lineage.extractorPath 2>/dev/null || true)"
  if [ -z "$configured" ]; then
    printf '%s\n' "$LINEAGE_DEFAULT_EXTRACTOR"
    return 0
  fi

  if [[ "$configured" = /* ]]; then
    printf '%s\n' "$configured"
  else
    printf '%s\n' "${repo_root}/${configured}"
  fi
}

json_is_valid_file() {
  local file_path="$1"

  if command -v jq >/dev/null 2>&1; then
    jq -e . "$file_path" >/dev/null 2>&1
    return $?
  fi

  if command -v python3 >/dev/null 2>&1; then
    python3 - "$file_path" <<'PY' >/dev/null 2>&1
import json
import sys

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as f:
    json.load(f)
PY
    return $?
  fi

  if command -v python >/dev/null 2>&1; then
    python - "$file_path" <<'PY' >/dev/null 2>&1
import json
import sys

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as f:
    json.load(f)
PY
    return $?
  fi

  # Last-resort shape check if no JSON parser is installed.
  local first_char
  first_char="$(sed -e 's/^[[:space:]]*//' "$file_path" | head -c 1 || true)"
  [ "$first_char" = "{" ] || [ "$first_char" = "[" ]
}

acquire_repo_lock() {
  local git_dir="$1"
  local lock_dir="${git_dir}/lineage.lock"
  local attempt=0
  local max_attempts=40

  while [ "$attempt" -lt "$max_attempts" ]; do
    if mkdir "$lock_dir" 2>/dev/null; then
      printf '%s\n' "$$" > "${lock_dir}/pid" 2>/dev/null || true
      printf '%s\n' "$lock_dir"
      return 0
    fi

    if [ -f "${lock_dir}/pid" ]; then
      local lock_pid
      lock_pid="$(cat "${lock_dir}/pid" 2>/dev/null || true)"
      if [ -n "$lock_pid" ] && ! kill -0 "$lock_pid" 2>/dev/null; then
        rm -rf "$lock_dir" 2>/dev/null || true
        continue
      fi
    fi

    sleep 0.1
    attempt=$((attempt + 1))
  done

  return 1
}

release_repo_lock() {
  local lock_dir="$1"
  [ -n "$lock_dir" ] || return 0
  rm -rf "$lock_dir" 2>/dev/null || true
}

note_exists() {
  local notes_ref="$1"
  local commit="$2"
  git notes --ref "$notes_ref" show "$commit" >/dev/null 2>&1
}

rewrite_in_progress() {
  local git_dir
  git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"
  [ -n "$git_dir" ] || return 1

  [ -d "${git_dir}/rebase-merge" ] && return 0
  [ -d "${git_dir}/rebase-apply" ] && return 0
  [ -f "${git_dir}/CHERRY_PICK_HEAD" ] && return 0
  [ -f "${git_dir}/REVERT_HEAD" ] && return 0
  return 1
}

attach_note_for_commit() {
  local commit="$1"
  local event="$2"

  if ! git cat-file -e "${commit}^{commit}" >/dev/null 2>&1; then
    warn "commit '$commit' does not exist"
    repo_log "WARN" "Commit '$commit' not found for event '$event'"
    return 1
  fi

  local repo_root
  repo_root="$(git rev-parse --show-toplevel)"

  local git_dir
  git_dir="$(git rev-parse --git-dir)"

  local notes_ref
  notes_ref="$(resolve_notes_ref)"

  local extractor_path
  extractor_path="$(resolve_extractor_path "$repo_root")"
  if [ ! -f "$extractor_path" ]; then
    warn "extractor script missing at '$extractor_path'"
    repo_log "ERROR" "Extractor missing at '$extractor_path' for commit '$commit'"
    return 1
  fi
  if [ ! -x "$extractor_path" ]; then
    warn "extractor script is not executable: '$extractor_path'"
    repo_log "ERROR" "Extractor not executable at '$extractor_path' for commit '$commit'"
    return 1
  fi

  local lock_dir
  lock_dir="$(acquire_repo_lock "$git_dir" || true)"
  if [ -z "$lock_dir" ]; then
    warn "could not acquire lineage lock under '$git_dir'; skipping note capture"
    repo_log "WARN" "Lock timeout for commit '$commit' event '$event'"
    return 1
  fi

  local tmp_payload
  tmp_payload="$(mktemp "${TMPDIR:-/tmp}/lineage-payload.XXXXXX")"
  local tmp_existing
  tmp_existing="$(mktemp "${TMPDIR:-/tmp}/lineage-existing.XXXXXX")"
  local tmp_stderr
  tmp_stderr="$(mktemp "${TMPDIR:-/tmp}/lineage-extractor-stderr.XXXXXX")"

  local rc=0
  local extractor_rc=0
  set +e
  LINEAGE_REPO_ROOT="$repo_root" \
  LINEAGE_COMMIT="$commit" \
  LINEAGE_EVENT="$event" \
  "$extractor_path" >"$tmp_payload" 2>"$tmp_stderr"
  extractor_rc=$?
  set -e

  if [ "$extractor_rc" -ne 0 ]; then
    local stderr_preview
    stderr_preview="$(sed -n '1,5p' "$tmp_stderr" 2>/dev/null || true)"
    warn "extractor failed for '$commit' (exit ${extractor_rc})"
    [ -n "$stderr_preview" ] && warn "extractor stderr: ${stderr_preview}"
    repo_log "ERROR" "Extractor failed for '$commit' (event '$event', rc=${extractor_rc})"
    rc=1
  fi

  if [ "$rc" -eq 0 ] && [ ! -s "$tmp_payload" ]; then
    warn "extractor produced empty payload for '$commit'"
    repo_log "ERROR" "Empty payload for '$commit' (event '$event')"
    rc=1
  fi

  if [ "$rc" -eq 0 ] && ! json_is_valid_file "$tmp_payload"; then
    warn "extractor payload is not valid JSON for '$commit'"
    repo_log "ERROR" "Invalid JSON payload for '$commit' (event '$event')"
    rc=1
  fi

  if [ "$rc" -eq 0 ] && note_exists "$notes_ref" "$commit"; then
    if git notes --ref "$notes_ref" show "$commit" >"$tmp_existing" 2>/dev/null; then
      if cmp -s "$tmp_existing" "$tmp_payload"; then
        repo_log "INFO" "Note already up to date for '$commit' (event '$event')"
        rc=0
      fi
    fi
  fi

  if [ "$rc" -eq 0 ] && ! cmp -s "$tmp_existing" "$tmp_payload" 2>/dev/null; then
    set +e
    git notes --ref "$notes_ref" add -f -F "$tmp_payload" "$commit" >/dev/null 2>&1
    local notes_rc=$?
    set -e
    if [ "$notes_rc" -ne 0 ]; then
      warn "failed to add note for '$commit' to '$notes_ref'"
      repo_log "ERROR" "git notes add failed for '$commit' ref '$notes_ref' (event '$event')"
      rc=1
    else
      repo_log "INFO" "Attached note for '$commit' ref '$notes_ref' (event '$event')"
    fi
  fi

  rm -f "$tmp_payload" "$tmp_existing" "$tmp_stderr" 2>/dev/null || true
  release_repo_lock "$lock_dir"
  return "$rc"
}

cmd_hook_post_commit() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    warn "not inside a git working tree; post-commit hook ignored"
    return 0
  fi

  if rewrite_in_progress; then
    repo_log "INFO" "Skipped post-commit note capture during rewrite operation"
    return 0
  fi

  local commit
  commit="$(git rev-parse --verify HEAD 2>/dev/null || true)"
  if [ -z "$commit" ]; then
    warn "could not resolve HEAD during post-commit"
    repo_log "WARN" "HEAD not resolved during post-commit"
    return 1
  fi

  attach_note_for_commit "$commit" "post-commit"
}

cmd_hook_post_rewrite() {
  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    warn "not inside a git working tree; post-rewrite hook ignored"
    return 0
  fi

  local rewrite_cmd="${1:-unknown}"
  local notes_ref
  notes_ref="$(resolve_notes_ref)"

  local copied=0
  local generated=0
  local skipped=0
  local failed=0
  local processed=0

  while IFS=' ' read -r old_commit new_commit _; do
    [ -n "${old_commit:-}" ] || continue
    [ -n "${new_commit:-}" ] || continue
    processed=$((processed + 1))

    if ! git cat-file -e "${new_commit}^{commit}" >/dev/null 2>&1; then
      failed=$((failed + 1))
      continue
    fi

    if note_exists "$notes_ref" "$new_commit"; then
      skipped=$((skipped + 1))
      continue
    fi

    if note_exists "$notes_ref" "$old_commit"; then
      if git notes --ref "$notes_ref" copy -f "$old_commit" "$new_commit" >/dev/null 2>&1; then
        copied=$((copied + 1))
      else
        failed=$((failed + 1))
      fi
    else
      if attach_note_for_commit "$new_commit" "post-rewrite-${rewrite_cmd}"; then
        generated=$((generated + 1))
      else
        failed=$((failed + 1))
      fi
    fi
  done

  repo_log "INFO" "post-rewrite '$rewrite_cmd': processed=${processed} copied=${copied} generated=${generated} skipped=${skipped} failed=${failed}"

  [ "$failed" -eq 0 ]
}

resolve_hooks_dir_for_repo() {
  local repo_root="$1"
  local hooks_path

  hooks_path="$(git -C "$repo_root" config --local --get core.hooksPath 2>/dev/null || true)"
  if [ -z "$hooks_path" ]; then
    local git_dir
    git_dir="$(git -C "$repo_root" rev-parse --git-dir)"
    printf '%s\n' "${git_dir}/hooks"
    return 0
  fi

  if [[ "$hooks_path" == "~/"* ]]; then
    hooks_path="${HOME}/${hooks_path#~/}"
  fi

  if [[ "$hooks_path" = /* ]]; then
    printf '%s\n' "$hooks_path"
  else
    printf '%s\n' "${repo_root}/${hooks_path}"
  fi
}

write_post_commit_wrapper() {
  local target="$1"
  local lineage_bin="$2"
  cat >"$target" <<EOF
#!/usr/bin/env bash
set -euo pipefail
# ${LINEAGE_TOOL_MARKER}
LINEAGE_BIN="$lineage_bin"
LEGACY_HOOK="\${BASH_SOURCE[0]}.pre-lineage"

if [ -x "\$LEGACY_HOOK" ]; then
  set +e
  "\$LEGACY_HOOK" "\$@"
  legacy_rc=\$?
  set -e
  if [ "\$legacy_rc" -ne 0 ]; then
    printf "lineage: warning: legacy post-commit hook failed (rc=%d): %s\n" "\$legacy_rc" "\$LEGACY_HOOK" >&2
  fi
fi

set +e
"\$LINEAGE_BIN" hook post-commit "\$@"
lineage_rc=\$?
set -e
if [ "\$lineage_rc" -ne 0 ]; then
  printf "lineage: warning: lineage post-commit hook failed (rc=%d)\n" "\$lineage_rc" >&2
fi

exit 0
EOF
}

write_post_rewrite_wrapper() {
  local target="$1"
  local lineage_bin="$2"
  cat >"$target" <<EOF
#!/usr/bin/env bash
set -euo pipefail
# ${LINEAGE_TOOL_MARKER}
LINEAGE_BIN="$lineage_bin"
LEGACY_HOOK="\${BASH_SOURCE[0]}.pre-lineage"
TMP_INPUT="\$(mktemp "\${TMPDIR:-/tmp}/lineage-post-rewrite.XXXXXX")"

cleanup() {
  rm -f "\$TMP_INPUT" 2>/dev/null || true
}
trap cleanup EXIT

cat > "\$TMP_INPUT"

if [ -x "\$LEGACY_HOOK" ]; then
  set +e
  "\$LEGACY_HOOK" "\$@" < "\$TMP_INPUT"
  legacy_rc=\$?
  set -e
  if [ "\$legacy_rc" -ne 0 ]; then
    printf "lineage: warning: legacy post-rewrite hook failed (rc=%d): %s\n" "\$legacy_rc" "\$LEGACY_HOOK" >&2
  fi
fi

set +e
"\$LINEAGE_BIN" hook post-rewrite "\$@" < "\$TMP_INPUT"
lineage_rc=\$?
set -e
if [ "\$lineage_rc" -ne 0 ]; then
  printf "lineage: warning: lineage post-rewrite hook failed (rc=%d)\n" "\$lineage_rc" >&2
fi

exit 0
EOF
}

install_hook_wrapper() {
  local hooks_dir="$1"
  local hook_name="$2"
  local lineage_bin="$3"
  local force="$4"

  local target="${hooks_dir}/${hook_name}"
  local backup="${target}.pre-lineage"

  if [ -e "$target" ]; then
    if grep -q "$LINEAGE_TOOL_MARKER" "$target" 2>/dev/null; then
      :
    else
      if [ -e "$backup" ] && [ "$force" -ne 1 ]; then
        die "hook conflict for '${hook_name}': both '${target}' and '${backup}' exist. Re-run with --force to rotate backups."
      fi
      if [ -e "$backup" ] && [ "$force" -eq 1 ]; then
        local rotated_backup
        rotated_backup="${backup}.$(date +%s)"
        mv "$backup" "$rotated_backup"
      fi
      mv "$target" "$backup"
    fi
  fi

  case "$hook_name" in
    post-commit) write_post_commit_wrapper "$target" "$lineage_bin" ;;
    post-rewrite) write_post_rewrite_wrapper "$target" "$lineage_bin" ;;
    *) die "unsupported hook '${hook_name}'" ;;
  esac
  chmod +x "$target"
}

ensure_config_contains() {
  local repo_root="$1"
  local key="$2"
  local value="$3"

  if git -C "$repo_root" config --local --get-all "$key" 2>/dev/null | grep -Fxq "$value"; then
    return 0
  fi

  git -C "$repo_root" config --local --add "$key" "$value"
}

remove_config_value() {
  local repo_root="$1"
  local key="$2"
  local value="$3"

  local tmp_values
  tmp_values="$(mktemp "${TMPDIR:-/tmp}/lineage-config-values.XXXXXX")"
  git -C "$repo_root" config --local --get-all "$key" >"$tmp_values" 2>/dev/null || true

  if ! grep -Fxq "$value" "$tmp_values" 2>/dev/null; then
    rm -f "$tmp_values" 2>/dev/null || true
    return 0
  fi

  git -C "$repo_root" config --local --unset-all "$key" >/dev/null 2>&1 || true
  while IFS= read -r existing_value; do
    [ "$existing_value" = "$value" ] && continue
    git -C "$repo_root" config --local --add "$key" "$existing_value"
  done <"$tmp_values"

  rm -f "$tmp_values" 2>/dev/null || true
}

cmd_install() {
  local repo_path="."
  local extractor_path="$LINEAGE_DEFAULT_EXTRACTOR"
  local notes_ref="$LINEAGE_DEFAULT_NOTES_REF"
  local force=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --extractor)
        shift
        [ $# -gt 0 ] || die "--extractor requires a path"
        extractor_path="$1"
        shift
        ;;
      --notes-ref)
        shift
        [ $# -gt 0 ] || die "--notes-ref requires a ref value"
        notes_ref="$1"
        shift
        ;;
      --force)
        force=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        repo_path="$1"
        shift
        ;;
    esac
  done

  [ -d "$repo_path" ] || die "repo path does not exist: '$repo_path'"
  if ! git -C "$repo_path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    die "path is not inside a git working tree: '$repo_path'"
  fi

  if ! validate_notes_ref "$notes_ref"; then
    die "invalid notes ref '$notes_ref'; expected prefix 'refs/notes/'"
  fi

  local repo_root
  repo_root="$(git -C "$repo_path" rev-parse --show-toplevel)"

  local hooks_dir
  hooks_dir="$(resolve_hooks_dir_for_repo "$repo_root")"
  mkdir -p "$hooks_dir"

  if [[ "$extractor_path" != /* ]]; then
    extractor_path="${repo_root}/${extractor_path}"
  fi

  if [ ! -f "$extractor_path" ]; then
    die "extractor script not found at '$extractor_path'"
  fi

  if [ ! -x "$extractor_path" ]; then
    warn "extractor is not executable, attempting to chmod +x: '$extractor_path'"
    chmod +x "$extractor_path" || die "unable to make extractor executable: '$extractor_path'"
  fi

  local lineage_bin="${LINEAGE_ROOT}/bin/lineage"
  [ -x "$lineage_bin" ] || die "lineage binary not executable at '$lineage_bin'"

  install_hook_wrapper "$hooks_dir" "post-commit" "$lineage_bin" "$force"
  install_hook_wrapper "$hooks_dir" "post-rewrite" "$lineage_bin" "$force"

  git -C "$repo_root" config --local lineage.notesRef "$notes_ref"
  git -C "$repo_root" config --local lineage.extractorPath "$extractor_path"
  git -C "$repo_root" config --local lineage.installedBy "$LINEAGE_ROOT"
  remove_config_value "$repo_root" "notes.rewriteRef" "$notes_ref"
  ensure_config_contains "$repo_root" "notes.displayRef" "$notes_ref"

  info "installed hooks into '${hooks_dir}' for repo '${repo_root}'"
  info "configured lineage.extractorPath='${extractor_path}'"
  info "configured lineage.notesRef='${notes_ref}'"
  info "configured notes.rewriteRef cleanup for '${notes_ref}' (rewrite handled by hook)"
  info "lineage is active for new commits in this repo"
}

cmd_attach() {
  local commit=""
  local event="manual"

  while [ $# -gt 0 ]; do
    case "$1" in
      --event)
        shift
        [ $# -gt 0 ] || die "--event requires a value"
        event="$1"
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        if [ -z "$commit" ]; then
          commit="$1"
          shift
        else
          die "unexpected argument: '$1'"
        fi
        ;;
    esac
  done

  [ -n "$commit" ] || die "attach requires <commit-ish>"
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "attach must run inside a git working tree"

  local resolved
  resolved="$(git rev-parse --verify "${commit}^{commit}" 2>/dev/null || true)"
  [ -n "$resolved" ] || die "unable to resolve commit '$commit'"

  attach_note_for_commit "$resolved" "$event"
}

cmd_hook() {
  [ $# -gt 0 ] || die "hook requires a subcommand"
  local hook_name="$1"
  shift

  case "$hook_name" in
    post-commit) cmd_hook_post_commit "$@" ;;
    post-rewrite) cmd_hook_post_rewrite "$@" ;;
    *) die "unsupported hook subcommand '$hook_name'" ;;
  esac
}

main() {
  if [ $# -eq 0 ]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    install) cmd_install "$@" ;;
    hook) cmd_hook "$@" ;;
    attach) cmd_attach "$@" ;;
    help|-h|--help) usage ;;
    *)
      die "unknown command '$cmd' (run 'lineage help')"
      ;;
  esac
}

main "$@"
