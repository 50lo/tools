#!/usr/bin/env bash
set -euo pipefail

TOOL_NAME="git-copy"
SRC_PATH="$(dirname "$0")/src/${TOOL_NAME}"
TARGET_DIR="${HOME}/bin"
TARGET_PATH="${TARGET_DIR}/${TOOL_NAME}"

MAN_SOURCE="$(dirname "$0")/man/${TOOL_NAME}.1"

echo "Installing ${TOOL_NAME}..."

# Check that TARGET_DIR exists
if [[ ! -d "${TARGET_DIR}" ]]; then
  echo "Error: ${TARGET_DIR} doesn't exist" >&2
  exit 1
fi

# Check permissions
if [[ ! -w "$TARGET_DIR" ]]; then
  echo "  You don't have write permission to ${TARGET_DIR}."
  echo "    Try running with sudo:"
  echo "    sudo $0"
  exit 1
fi

# Backup existing version if any
if [[ -f "$TARGET_PATH" ]]; then
  BACKUP_PATH="${TARGET_PATH}.$(date +%Y%m%d%H%M%S).bak"
  echo "Found existing ${TOOL_NAME}, backing up to ${BACKUP_PATH}"
  mv "$TARGET_PATH" "$BACKUP_PATH"
fi

# Copy and set permissions
cp "$SRC_PATH" "$TARGET_PATH"
chmod +x "$TARGET_PATH"

echo "${TOOL_NAME} installed successfully at ${TARGET_PATH}"

if [[ -f "$MAN_SOURCE" ]]; then
  echo "Installing manual page..."
  MAN_TARGET=""
  for candidate in /usr/local/share/man/man1 /usr/share/man/man1; do
    if mkdir -p "$candidate" >/dev/null 2>&1; then
      if cp "$MAN_SOURCE" "$candidate/${TOOL_NAME}.1" >/dev/null 2>&1; then
        MAN_TARGET="$candidate/${TOOL_NAME}.1"
        echo "Manual page installed at ${MAN_TARGET}"
        break
      else
        echo "  Skipping ${candidate} (insufficient permissions)" >&2
      fi
    fi
  done

  if [[ -z "$MAN_TARGET" ]]; then
    FALLBACK_DIR="${HOME}/share/man/man1"
    mkdir -p "$FALLBACK_DIR"
    cp "$MAN_SOURCE" "$FALLBACK_DIR/${TOOL_NAME}.1"
    MAN_TARGET="$FALLBACK_DIR/${TOOL_NAME}.1"
    echo "Manual page installed at ${MAN_TARGET}"
  fi
else
  echo "Manual page source not found at ${MAN_SOURCE}" >&2
fi

echo
echo "To verify, run:"
echo "  git copy --help"
